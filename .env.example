# Copy this file to `.env` and fill in real values.
# `.env` is git-ignored; `.env.example` is committed as a template.

# Remote SAM GPU server (public IP — do NOT commit the real address)
GP8_SAM_SERVER_IP=<sam-server-hostname-or-ip>
GP8_SAM_SERVER_PORT=7150

# Optional overrides:
# GP8_VENV_PYTHON=/custom/path/.venv/bin/python
